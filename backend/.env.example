PORT=9001
JWT_SECRET=change-me

# Shared with digital-accessibility-intelligence for usage-report callbacks.
INTELLIGENCE_SERVICE_KEY=change-me-too

# Local SQLite database
DB_DIALECT=sqlite
DATABASE_STORAGE=./data/database.sqlite

# Optional Postgres settings. Set DB_DIALECT=postgres before using these.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=verify-full
